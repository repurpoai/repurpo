NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash
SUPADATA_API_KEY=your-supadata-api-key
SUPADATA_BASE_URL=https://api.supadata.ai/v1
SERPAPI_API_KEY=your-serpapi-api-key
SERPAPI_BASE_URL=https://serpapi.com/search.json
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_AI_IMAGE_MODEL=@cf/stabilityai/stable-diffusion-xl-base-1.0
DODO_PAYMENTS_API_KEY=your-dodo-payments-api-key
DODO_PAYMENTS_WEBHOOK_KEY=your-dodo-payments-webhook-secret
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_RETURN_URL=https://your-domain.com/checkout/success
DODO_PAYMENTS_PORTAL_RETURN_URL=https://your-domain.com/profile
DODO_PAYMENTS_PLUS_PRODUCT_ID=your-plus-product-id
DODO_PAYMENTS_PRO_PRODUCT_ID=your-pro-product-id

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional fallback order for Gemini when the primary model is busy
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash
